@using ProjectManager.Services
@if (Details != null)
{
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Project Stats</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Stars:</span>
                        <span class="fw-bold">@Details.StargazersCount</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Forks:</span>
                        <span class="fw-bold">@Details.ForksCount</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Open Issues:</span>
                        <span class="fw-bold">@Details.OpenIssuesCount</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Watchers:</span>
                        <span class="fw-bold">@Details.WatchersCount</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>License:</span>
                        <span class="fw-bold">@(Details.License?.Name ?? "None")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Created:</span>
                        <span class="fw-bold">@Details.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Contributors</h5>
                </div>
                <div class="card-body">
                    @if (Contributors?.Any() == true)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var contributor in Contributors)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex align-items-center">
                                        <img src="https://github.com/@(contributor.Login).png"
                                             alt="@contributor.Login"
                                             class="rounded-circle"
                                             style="width: 32px; height: 32px;" />
                                        <div class="ms-3">
                                            <h6 class="mb-0">@contributor.Login</h6>
                                            <small class="text-muted">
                                                @contributor.Contributions commits
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No contributors found</p>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <p>No info available</p>
}

@code {
    [Parameter]
    public GitHubRepoDetails? Details { get; set; }

    [Parameter]
    public IEnumerable<GitHubContributor>? Contributors { get; set; }
}