<div style="flex:0 0 @(Width + "px"); background:#343541; display:flex; flex-direction:column; overflow:hidden; border-left:1px solid #444;">
    <div class="flex-grow-1 d-flex flex-column" style="overflow-y:auto; padding:10px 10px 0 10px;">
        <div style="display:flex; margin-bottom:16px;">
            <div style="max-width:75%; background:#444654; color:#fff; padding:12px 16px; border-radius:8px; line-height:1.5; font-size:0.95rem;">
                Hi, how can I help you today?
            </div>
        </div>

        <div style="display:flex; justify-content:end; margin-bottom:16px;">
            <div style="max-width:75%; background:#40414F; color:#fff; padding:12px 16px; border-radius:8px; line-height:1.5; font-size:0.95rem;">
                I need help with my project.
            </div>
        </div>
    </div>

    <div style="border-top:1px solid #444; padding:10px; background:#343541;">
        <div class="input-group" style="background:#40414F; border-radius:8px; align-items:center;">
            <textarea class="form-control"
                      style="background:transparent; color:#fff; border:none; resize:none; padding:12px; height:60px; font-size:1rem; line-height:1.4;"
                      placeholder="Type your message here..."></textarea>
            <button class="btn" style="background:transparent; border:none; padding:8px;" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:28px; height:28px;">
                    <line x1="22" y1="2" x2="11" y2="13"></line>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Width { get; set; }
}